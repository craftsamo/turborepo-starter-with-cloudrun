{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "docs/instructions/**/*.md",
    "apps/**/AGENTS.md",
    "packages/**/AGENTS.md"
  ],
  "references": {
    "upstream": {
      "repository": "craftsamo/turborepo-starter",
      "branch": "main",
      "description": "Upstream turborepo-starter repository — use to compare fork-specific changes, verify upstream behavior, and assist with rebasing"
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      // Read / inspect (safe)
      "ls*": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "tail -f*": "ask",
      "tail -F*": "ask",
      "wc *": "allow",
      "stat *": "allow",
      "file *": "allow",
      "du *": "allow",
      "df*": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "jq *": "allow",
      "pwd*": "allow",
      "which *": "allow",
      "whoami*": "allow",
      "uname*": "allow",
      "date*": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "realpath *": "allow",
      "dirname *": "allow",
      "basename *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "tr *": "allow",
      "nl *": "allow",
      "column *": "allow",
      "diff *": "allow",
      "comm *": "allow",
      "tree*": "allow",
      "type *": "allow",
      "command -v*": "allow",
      "printenv *": "allow",
      "base64 *": "allow",
      "xxd *": "allow",
      "shasum *": "allow",
      "md5 *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "tac *": "allow",
      "rev *": "allow",
      "paste *": "allow",
      "join *": "allow",
      "fold *": "allow",
      "fmt *": "allow",
      "expand *": "allow",
      "unexpand *": "allow",
      "seq *": "allow",
      "expr *": "allow",
      "cmp *": "allow",
      "od *": "allow",
      "hexdump *": "allow",
      "strings *": "allow",
      "egrep *": "allow",
      "fgrep *": "allow",
      "gron *": "allow",
      "cksum *": "allow",
      "sha1sum *": "allow",
      "sha256sum *": "allow",
      "sha512sum *": "allow",
      // System info
      "id*": "allow",
      "groups*": "allow",
      "hostname*": "allow",
      "uptime*": "allow",
      "arch*": "allow",
      "nproc*": "allow",
      "sw_vers*": "allow",
      "getconf *": "allow",
      "locale*": "allow",
      "cal*": "allow",
      "ps *": "allow",
      "pgrep *": "allow",
      // Docs
      "man *": "allow",
      "whatis *": "allow",
      "apropos *": "allow",
      "tldr *": "allow",
      // Git (non-destructive: allow / destructive & history-rewrite: ask)
      "git *": "allow",
      "git push*": "ask",
      "git rebase*": "ask",
      "git reset*": "ask",
      "git checkout*": "ask",
      "git restore*": "ask",
      "git clean*": "ask",
      "git commit*": "ask",
      "git merge*": "ask",
      "git revert*": "ask",
      "git cherry-pick*": "ask",
      "git config*": "ask",
      // Package manager / build / test (this repo: pnpm + nps + turbo + vitest)
      "pnpm *": "allow",
      "nps *": "allow",
      "vitest*": "allow",
      "gh *": "allow",
      // Re-gate network-fetch-and-run / value-exposing forms back to ask
      "pnpm dlx*": "ask",
      "pnpm exec*": "ask",
      "pnpm create*": "ask",
      "gh auth*": "ask",
      "gh secret*": "ask",
      // Note: npx / bunx / node / bash -c stay ask by default
      // Version checks
      "node --version*": "allow",
      "node -v*": "allow",
      // Docker (read-only; repo has Dockerfile + docker-compose.web.yml)
      "docker --version*": "allow",
      "docker ps*": "allow",
      "docker images*": "allow",
      "docker image ls*": "allow",
      "docker logs*": "allow",
      "docker logs -f*": "ask",
      "docker logs --follow*": "ask",
      "docker inspect*": "allow",
      "docker info*": "allow",
      "docker compose ls*": "allow",
      "docker compose ps*": "allow",
      // Deny block pinned last (not overridden by allows above)
      "sudo *": "deny",
      "wget *": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      "shutdown*": "deny",
      "reboot*": "deny",
      "halt*": "deny",
      "diskutil erase*": "deny",
      ":(){ :|:& }; *": "deny",
      // Block reading .env via bash (best-effort)
      "cat *.env": "deny",
      "head *.env": "deny",
      "tail *.env": "deny",
      "cat *.env.*": "deny"
    },
    "skill": {
      "*": "ask",
      "add-cloudrun-app": "allow",
      "add-error-code": "allow",
      "add-next-route": "allow",
      "add-redux-slice": "allow",
      "add-shared-type": "allow",
      "add-ui-component": "allow",
      "add-web-test": "allow",
      "edit-middleware": "allow",
      "fork-layer-placement": "allow",
      "manage-deploy-secrets": "allow",
      "nextjs-rsc-streaming": "allow",
      "nextjs-server-action": "allow",
      "setup-gcp-deploy": "allow",
      "sync-upstream": "allow"
    }
  }
}
