{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "docs/instructions/**/*.md",
    "apps/**/AGENTS.md",
    "packages/**/AGENTS.md"
  ],
  "references": {
    "upstream": {
      "repository": "craftsamo/turborepo-starter",
      "branch": "main",
      "description": "Upstream turborepo-starter repository — use to compare fork-specific changes, verify upstream behavior, and assist with rebasing"
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "sudo *": "deny",
      "wget *": "deny",
      "dd *": "deny",
      ":(){ :|:& }; *": "deny",
      "nps *": "allow"
    }
  }
}
