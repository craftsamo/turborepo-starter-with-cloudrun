{
  "name": "turborepo-starter-with-cloudrun",
  "description": "Boilerplate for streamlined development of Turborepo applications with best practices and curated configurations.",
  "author": "craftsamo",
  "license": "MIT",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "commit": "cz",
    "postinstall": "node -e \"const f='scripts/link-agent-skills.mjs';if(require('fs').existsSync(f))require('child_process').execFileSync(process.execPath,[f],{stdio:'inherit'})\""
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "cz-customizable": "^7.4.0",
    "husky": "^9.1.7",
    "shadcn": "^3.8.4",
    "turbo": "2.9.14",
    "typescript": "^5.1.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.3",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable",
      "cz-customizable": {
        "config": ".cz-config.js"
      }
    }
  }
}
