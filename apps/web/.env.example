## Base URL used for absolute links, sitemap, robots, and API calls.
## Defaults to http://localhost when unset (see apps/web/src/app/*).
BASE_URL=

## Logger verbosity: verbose | debug | info | log | warn | error | fatal
## Defaults to "info" when unset (see apps/web/src/lib/logger.ts).
LOG_LEVEL=

## Logger output format: text | json (default: text; json for Cloud Run)
LOG_FORMAT=

## Upstash Redis REST (used by the structured logger for Cloud Run)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

## Environment variables used in Cloud Run (populated at deploy time)
GITHUB_SHA=
CONTAINER_IMAGE=
CLOUD_RUN_SERVICE_NAME=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_PROJECT_NUMBER=
ENVIRONMENT=
CLOUD_RUN_SERVICE_ACCOUNT=
